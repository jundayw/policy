{
    "name": "jundayw/policy",
    "description": "A flexible policy verification system for Laravel, supporting dynamic return of permission identifiers through model methods and providing easy integration with middleware.",
    "keywords": [
        "laravel",
        "policy"
    ],
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/jundayw/policy",
    "authors": [
        {
            "name": "jundayw",
            "email": "jundayw@126.com"
        }
    ],
    "require": {
        "php": "^8.0"
    },
    "require-dev": {
        "code-lts/doctum": "^5.0"
    },
    "autoload": {
        "psr-4": {
            "Jundayw\\Policy\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "docs": "@php vendor/bin/doctum.php update doctum.php"
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.x-dev"
        },
        "laravel": {
            "providers": [
                "Jundayw\\Policy\\PolicyServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
